{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipboard-manager",
  "version": "0.1.4",
  "identifier": "com.adriano.clipboard-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipX",
        "width": 400,
        "height": 600,
        "decorations": false,
        "visible": false,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 400,
        "height": 400,
        "decorations": true,
        "visible": false,
        "center": true,
        "url": "settings.html"
      },
      {
        "label": "about",
        "title": "About ClipX",
        "width": 280,
        "height": 120,
        "decorations": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "url": "about.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

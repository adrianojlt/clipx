{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipX",
  "version": "0.1.28",
  "identifier": "com.adriano.clipx",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClipX",
        "width": 600,
        "height": 700,
        "decorations": false,
        "visible": false,
        "backgroundColor": [30, 30, 30, 255],
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 1200,
        "height": 800,
        "decorations": true,
        "visible": false,
        "center": true,
        "url": "settings.html"
      },
      {
        "label": "about",
        "title": "About ClipX",
        "width": 280,
        "height": 120,
        "decorations": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "url": "about.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "ClipX Dev"
    }
  }
}
